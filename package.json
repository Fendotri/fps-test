{
    "name": "threejs-cube-gunman",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:lite": "vite build --mode lite && node scripts/build-size-check.mjs --dir cube_gunman --max-mb 8 --top 10",
        "size:check": "node scripts/build-size-check.mjs --dir cube_gunman --max-mb 8 --top 10",
        "tscheck": "vue-tsc --noEmit",
        "combat:smoke": "node scripts/combat-smoke.mjs",
        "backend:seed:leaderboard": "node scripts/seed-leaderboard-dummy.mjs",
        "preview": "vite preview",
        "backend:start": "node backend/server.mjs",
        "backend:dev": "node --watch backend/server.mjs"
    },
    "dependencies": {
        "normalize.css": "^8.0.1",
        "sass": "^1.56.1",
        "three": "^0.148.0",
        "vue": "^3.2.41"
    },
    "devDependencies": {
        "@types/node": "^18.11.9",
        "@types/three": "^0.148.0",
        "@vitejs/plugin-vue": "^3.2.0",
        "@vitejs/plugin-vue-jsx": "^2.1.1",
        "kolorist": "^1.6.0",
        "micromatch": "^4.0.5",
        "path": "^0.12.7",
        "scss": "^0.2.4",
        "typescript": "^4.6.4",
        "vite": "^3.2.3",
        "vue-tsc": "^1.0.9",
        "ws": "^8.11.0"
    }
}
